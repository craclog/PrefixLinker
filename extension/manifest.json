{
  "manifest_version": 3,
  "name": "PrefixLinker",
  "version": "1.0.0",
  "description": "Turns prefix-matched text (e.g. CSWPR-12345) into clickable links.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["core.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PrefixLinker"
  }
}
